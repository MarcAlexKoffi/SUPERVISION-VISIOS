rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPER FUNCTIONS ---
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if authenticated user is admin
    function isAdmin() {
      // NOTE: This costs 1 read per request. For high traffic, consider Custom Claims.
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Check if user is the owner of the resource (based on user_id field)
    function isResourceOwner() {
      return isAuthenticated() && resource.data.user_id == request.auth.uid;
    }

    // Check if user is creating a resource assigned to themselves
    function assignsToSelf() {
       return request.resource.data.user_id == request.auth.uid;
    }

    // --- COLLECTION RULES ---

    // 1. Users
    // - Read: Self or Admin
    // - Create: Authenticated user creating their OWN profile
    // - Update: Self or Admin
    // - Delete: Admin only
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId; 
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // 2. Resources (Teachers, Parcours, Classes, UEs)
    // ADMIN ONLY WRITE, AUTHENTICATED READ
    // Note: UEs might become user-specific later, but currently admin managed or public read?
    // Let's stick to AUTH READ / ADMIN WRITE for master data.
    
    match /teachers/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /parcours/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /classes/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // UEs: Actually, UEs are often personal teaching units.
    // If Admin manages all:
    // match /ues/{document=**} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    // BUT userController implied users fetch THEIR UEs.
    // So let's allow users to manage their OWN UEs.
    match /ues/{ueId} {
      allow read: if isAuthenticated(); // Supervisors need to see UEs to plan? Or just own?
      // If supervisions link to UE, supervisor needs to read UE details.
      // So Read: Authenticated.
      // Write: Admin or Owner.
      allow create: if isAuthenticated() && (isAdmin() || assignsToSelf());
      allow update, delete: if isAdmin() || isResourceOwner();
    }

    // 3. Plannings
    // - Read: All authenticated (Supervisors need to see schedule)
    // - Write: Admin (Scheduler) or maybe the Supervisor him/herself?
    // Let's assume Admin schedules, or maybe Supervisors pick slots.
    // If supervisors pick slots, they need create permission.
    // For now, let's allow Admin write.
    match /plannings/{planningId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // 4. Supervisions
    // - Read: Admin or Owner (Supervisor)
    // - Create: Authenticated (Supervisor filling report)
    // - Update/Delete: Admin or Owner
    match /supervisions/{supervisionId} {
      allow read: if isAdmin() || isResourceOwner();
      allow create: if isAuthenticated() && (isAdmin() || assignsToSelf());
      allow update, delete: if isAdmin() || isResourceOwner();
    }
  }
}
